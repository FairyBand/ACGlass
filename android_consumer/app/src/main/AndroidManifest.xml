<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.acglass.app">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:label="ACGlass"
        android:theme="@android:style/Theme.Material.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />
        <service
            android:name=".DisplayOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="display application overlay window" />
        </service>
        <activity
            android:name=".DisplayActivity"
            android:exported="true"
            android:theme="@style/ACGlassDisplayTheme"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden"
            android:documentLaunchMode="always"
            android:launchMode="standard">
            <layout
                android:defaultWidth="960dp"
                android:defaultHeight="640dp"
                android:minWidth="360dp"
                android:minHeight="240dp"
                android:gravity="center" />
            <property
                android:name="android.window.PROPERTY_COMPAT_ALLOW_RESTRICTED_RESIZABILITY"
                android:value="true" />
        </activity>
        <receiver
            android:name=".AppsReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.acglass.app.SYNC_APPS" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
